---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-8 pb-6 border-b border-border text-center">
      <!-- 头像 -->
    <img 
      src="/astro_blog/avatar.jpg" 
      alt="头像"
      class="w-32 h-32 rounded-full mx-auto mb-4 object-cover"
    />
      
      <!-- 名称 -->
      <h1 class="text-3xl font-bold">Lirio</h1>
      
      <!-- 地址和 GitHub 水平排列 -->
      <div class="flex flex-wrap justify-center gap-x-7 gap-y-3 mt-2">
        <!-- 地址 -->
        <div class="flex flex-row items-center justify-center gap-x-2">
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a9 9 0 0 0-9 9c0 3.074 1.676 5.59 3.442 7.395a20.4 20.4 0 0 0 2.876 2.416l.426.29.2.133.377.24.336.205.416.242a1.87 1.87 0 0 0 1.854 0l.416-.242.52-.32.192-.125.41-.273a20.6 20.6 0 0 0 3.093-2.566C19.324 16.589 21 14.074 21 11a9 9 0 0 0-9-9zm0 2a7 7 0 0 1 7 7c0 2.322-1.272 4.36-2.871 5.996a18 18 0 0 1-2.222 1.91l-.458.326-.427.288-.39.25-.343.209-.289.169-.455-.269-.367-.23-.627-.417-.458-.326a18 18 0 0 1-2.222-1.91C6.272 15.361 5 13.322 5 11a7 7 0 0 1 7-7zm0 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/>
          </svg>
          <p class="text-gray-500 dark:text-gray-400">China / Beijing</p>
        </div>
        
        <!-- GitHub 链接 -->
        <a href="https://github.com/ljr0724" target="_blank" class="flex flex-row items-center justify-center gap-x-2 hover:opacity-75">
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.315 6.176c-.25-.638-.24-1.367-.129-2.034a6.8 6.8 0 0 1 2.12 1.07c.28.214.647.283.989.18A9.3 9.3 0 0 1 12 5c.961 0 1.874.14 2.703.391c.342.104.709.034.988-.18a6.8 6.8 0 0 1 2.119-1.07c.111.667.12 1.396-.128 2.033c-.15.384-.075.826.208 1.14C18.614 8.117 19 9.04 19 10c0 2.114-1.97 4.187-5.134 4.818c-.792.158-1.101 1.155-.495 1.726c.389.366.629.882.629 1.456v3a1 1 0 0 0 2 0v-3c0-.57-.12-1.112-.334-1.603C18.683 15.35 21 12.993 21 10c0-1.347-.484-2.585-1.287-3.622c.21-.82.191-1.646.111-2.28c-.071-.568-.17-1.312-.57-1.756c-.595-.659-1.58-.271-2.28-.032a9 9 0 0 0-2.125 1.045A11.4 11.4 0 0 0 12 3c-.994 0-1.953.125-2.851.356a9 9 0 0 0-2.125-1.045c-.7-.24-1.686-.628-2.281.031c-.408.452-.493 1.137-.566 1.719l-.005.038c-.08.635-.098 1.462.112 2.283C3.484 7.418 3 8.654 3 10c0 2.992 2.317 5.35 5.334 6.397A4 4 0 0 0 8 17.98l-.168.034c-.717.099-1.176.01-1.488-.122c-.76-.322-1.152-1.133-1.63-1.753c-.298-.385-.732-.866-1.398-1.088a1 1 0 0 0-.632 1.898c.558.186.944 1.142 1.298 1.566c.373.448.869.916 1.58 1.218c.682.29 1.483.393 2.438.276V21a1 1 0 0 0 2 0v-3c0-.574.24-1.09.629-1.456c.607-.572.297-1.568-.495-1.726C6.969 14.187 5 12.114 5 10c0-.958.385-1.881 1.108-2.684c.283-.314.357-.756.207-1.14z"/>
          </svg>
          <p>GitHub</p>
        </a>
      </div>
    </section>

    <!--精选文章板块 -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Posts:</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <!-- 教育经历 -->
    <section class="flex flex-col gap-y-5 md:flex-row md:gap-y-0 mt-12">
      <div class="text-xl font-semibold md:min-w-36">
        <h2>Education</h2>
      </div>
      <div class="flex flex-1 flex-col gap-y-3">
        <!-- 第一条教育经历 -->
        <div class="not-prose block relative rounded-2xl border bg-muted px-5 py-3">
          <div class="flex flex-col gap-y-1.5">
            <div class="flex flex-col gap-y-0.5">
              <a href="https://www.bupt.edu.cn/" target="_blank" class="text-lg font-medium hover:text-accent">
              北京邮电大学
              </a>
              <p class="text-muted-foreground">计算机科学技术</p>
              <p class="text-muted-foreground">August 2025 - Present</p>
            </div>
          </div>
        </div>
        
        <!-- 第二条教育经历 -->
        <div class="not-prose block relative rounded-2xl border bg-muted px-5 py-3">
          <div class="flex flex-col gap-y-1.5">
            <div class="flex flex-col gap-y-0.5">
              <a href="https://baike.baidu.com/item/%E5%8C%97%E4%BA%AC%E5%B8%82%E7%AC%AC%E4%B8%80%E4%B8%83%E4%B8%80%E4%B8%AD%E5%AD%A6/6779453" target="_blank" class="text-lg font-medium hover:text-accent">
              北京市第一七一中学
              </a>
              <p class="text-muted-foreground"></p>
              <p class="text-muted-foreground">August 2019 - July 2025</p>
            </div>
          </div>
        </div>
      </div>
    </section>
<!--
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">最新文章</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }
    

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        所有文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  -->   
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>